{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ILUMINATY",
  "version": "1.0.0",
  "identifier": "com.iluminaty.eye",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ILUMINATY — Eye of God",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8420 http://localhost:8420; img-src 'self' data: blob: http://127.0.0.1:8420; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "id": "iluminaty-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "ILUMINATY — Eye of God"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": ["English", "Spanish"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
